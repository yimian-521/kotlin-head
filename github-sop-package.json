{
  "name": "github-sop",
  "version": "0.2.1",
  "type": "sandbox_package",
  "entry": "github-sop.js",
  "runner": "node",
  "description": "GitHub 发版助手 — JSON管道 + HED按钮双入口",
  "actions": {
    "status":   { "desc": "远端vs本地版本状态" },
    "check":    { "desc": "差异检查，不推送" },
    "release":  { "desc": "自动走七步SOP", "params": ["version", "title", "body"] },
    "repos":    { "desc": "列出所有公开仓库" },
    "switch":   { "desc": "切换当前仓库", "params": ["repo"] }
  },
  "config": {
    "token":   { "env": "GITHUB_TOKEN", "desc": "GitHub经典密钥" },
    "repo":    { "default": "yimian-521/kotlin-head" },
    "allow_private": { "default": false }
  }
}
